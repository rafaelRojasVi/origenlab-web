---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import CtaSection from '../components/CtaSection.astro';
import Card from '../components/Card.astro';
import { categories } from '../data/categories';
---

<Layout
  title="Productos — OrigenLab"
  description="Catálogo de equipamiento e instrumentación para laboratorio. Categorías: instrumentación, reactivos, consumibles, equipos. OrigenLab, Valdivia."
>
  <PageHeader
    title="Productos"
    lead="Ofrecemos equipamiento, instrumentación, reactivos y consumibles para laboratorio. Explore las categorías y contáctenos para consultas de disponibilidad y cotizaciones."
  />

  <div class="mt-10">
    <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((cat) => (
        <li>
          <Card
            title={cat.name}
            href={`/categorias/${cat.slug}`}
            description={cat.description}
          />
        </li>
      ))}
    </ul>
  </div>

  <div class="mt-14">
    <CtaSection
      title="¿Busca un producto en particular?"
      description="Contáctenos para consultas de disponibilidad, especificaciones y cotizaciones."
      ctaText="Solicitar cotización"
      ctaHref="/contacto"
    />
  </div>
</Layout>
