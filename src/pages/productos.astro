---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import QuoteCTA from '../components/QuoteCTA.astro';
import Card from '../components/Card.astro';
import { categories } from '../data/categories';
import { company } from '../data/company';
---

<Layout
  title="Productos — OrigenLab"
  description={`Equipos para alimentos, control de calidad y laboratorio clínico. ${company.catalogNote}`}
>
  <PageHeader
    title="Productos"
    lead={`${company.primaryOffer} en tres categorías. ${company.catalogNote}`}
  />

  <div class="mt-10">
    <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((cat) => (
        <li>
          <Card
            title={cat.name}
            href={`/categorias/${cat.slug}`}
            description={cat.description}
          />
        </li>
      ))}
    </ul>
  </div>

  <div class="mt-14">
    <QuoteCTA
      title="¿Busca un equipo en particular?"
      description="Consulte por disponibilidad y cotización; sin compromiso."
    />
  </div>
</Layout>
