---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import CtaSection from '../components/CtaSection.astro';
import Card from '../components/Card.astro';
import { brands } from '../data/brands';
---

<Layout
  title="Marcas — OrigenLab"
  description="Marcas y proveedores con los que trabajamos. Equipamiento e instrumentación para laboratorio. OrigenLab, Valdivia."
>
  <PageHeader
    title="Marcas"
    lead="Trabajamos con fabricantes y distribuidores reconocidos en equipamiento e instrumentación para laboratorio. Consulte disponibilidad y cotizaciones para las marcas que necesite."
  />

  <div class="mt-10">
    <p class="text-slate-600">
      Seleccionamos a nuestros proveedores según estándares de calidad y servicio. Si busca una marca en particular o desea recomendaciones, contáctenos.
    </p>
    <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {brands.map((brand) => (
        <li>
          <Card title={brand.name} description="Disponible bajo consulta" />
        </li>
      ))}
    </ul>
  </div>

  <div class="mt-14">
    <CtaSection
      title="¿Necesita una marca o producto específico?"
      description="Consúltenos por disponibilidad y condiciones."
      ctaText="Contactar"
      ctaHref="/contacto"
    />
  </div>
</Layout>
