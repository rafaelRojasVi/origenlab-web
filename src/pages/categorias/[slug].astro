---
import Layout from '../../layouts/Layout.astro';
import { categories } from '../../data/categories';

export function getStaticPaths() {
  return categories.map((cat) => ({ params: { slug: cat.slug } }));
}

const { slug } = Astro.params;
const category = categories.find((c) => c.slug === slug);
if (!category) return Astro.redirect('/productos');
---

<Layout
  title={`${category.name} — OrigenLab`}
  description={category.description ?? `Productos en ${category.name}. OrigenLab.`}
>
  <h1 class="text-2xl font-bold text-slate-900">{category.name}</h1>
  {category.description && <p class="mt-4 text-slate-600">{category.description}</p>}
  <p class="mt-6">
    <a href="/productos" class="text-slate-600 hover:underline">← Volver a productos</a>
  </p>
</Layout>
