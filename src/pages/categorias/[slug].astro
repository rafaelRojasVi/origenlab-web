---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { categories } from '../../data/categories';

export function getStaticPaths() {
  return categories.map((cat) => ({ params: { slug: cat.slug } }));
}

const { slug } = Astro.params;
const category = categories.find((c) => c.slug === slug);
if (!category) return Astro.redirect('/productos');
---

<Layout
  title={`${category.name} — OrigenLab`}
  description={category.description ?? `Productos en ${category.name}. OrigenLab, equipamiento para laboratorio.`}
>
  <PageHeader
    title={category.name}
    lead={category.description}
  />

  <div class="mt-8 space-y-6 text-slate-600">
    <p>
      Contamos con opciones en esta categoría. Para consultas de disponibilidad, especificaciones o cotizaciones, contáctenos.
    </p>
    <p>
      <a href="/contacto" class="btn-primary inline-block">Contactar</a>
    </p>
  </div>

  <p class="mt-10">
    <a href="/productos" class="link-muted text-sm font-medium">← Volver a productos</a>
  </p>
</Layout>
