---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
}

const { title, subtitle, ctaText, ctaHref } = Astro.props;
---

<section class="py-16 text-center">
  <h1 class="text-3xl font-bold text-slate-900 md:text-4xl">{title}</h1>
  {subtitle && <p class="mt-4 max-w-2xl mx-auto text-lg text-slate-600">{subtitle}</p>}
  {ctaText && ctaHref && (
    <p class="mt-8">
      <a href={ctaHref} class="btn-primary">{ctaText}</a>
    </p>
  )}
</section>
