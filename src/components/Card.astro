---
interface Props {
  title: string;
  href?: string;
  description?: string;
  class?: string;
}

const { title, href, description, class: className = '' } = Astro.props;
---

{href ? (
  <a
    href={href}
    class={`card-elevated group block border-l-4 border-l-brand-600 ${className}`}
  >
    <h2 class="font-bold text-brand-950 transition group-hover:text-brand-700">{title}</h2>
    {description && <p class="mt-2 text-sm leading-relaxed text-slate-600">{description}</p>}
    <p class="mt-4 text-sm font-semibold text-brand-700 opacity-0 transition group-hover:opacity-100">
      Ver categoría →
    </p>
  </a>
) : (
  <div class={`card-elevated border-l-4 border-l-brand-600 ${className}`}>
    <h2 class="font-bold text-brand-950">{title}</h2>
    {description && <p class="mt-2 text-sm text-slate-600">{description}</p>}
  </div>
)}
