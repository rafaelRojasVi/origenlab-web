---
/**
 * Widget WhatsApp — área segura + tarjeta al hover + brillo vertical + pulso.
 */
import { whatsappUrl } from '../data/contact';

const href = whatsappUrl() + '?text=' + encodeURIComponent('Hola, escribo desde origenlab.cl — ');
---

<div class="wa-widget" aria-label="Consultas por WhatsApp">
  <div class="wa-inner">
    <div class="wa-card">
      <strong class="text-emerald-600">Consultas</strong><br />
      Respuestas por WhatsApp<br />
      <span class="text-slate-500">Lun–vie 9–18</span>
    </div>
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class="wa-btn"
      aria-label="Abrir WhatsApp"
    >
      <span class="wa-pulse wa-pulse--back" aria-hidden="true"></span>
      <span class="wa-pulse wa-pulse--front" aria-hidden="true"></span>
      <!-- Lucide-style message circle + puntos: nítido a tamaño FAB -->
      <svg
        class="wa-icon"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <circle cx="9.2" cy="10.5" r="0.9" fill="currentColor" />
        <circle cx="12" cy="10.5" r="0.9" fill="currentColor" />
        <circle cx="14.8" cy="10.5" r="0.9" fill="currentColor" />
      </svg>
    </a>
  </div>
</div>

<style>
  :root {
    --wa-gap: 0.75rem;
    --wa-edge: max(1rem, env(safe-area-inset-right, 0px));
    --wa-bottom: max(1rem, env(safe-area-inset-bottom, 0px));
    --wa-btn-size: 3.5rem;
    --wa-max-width: calc(100vw - 2rem);
  }

  .wa-widget {
    position: fixed;
    right: var(--wa-edge);
    bottom: var(--wa-bottom);
    z-index: 1000;
    max-width: var(--wa-max-width);
    overflow: visible;
    pointer-events: none;
  }

  .wa-inner {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    min-height: var(--wa-btn-size);
    pointer-events: auto;
  }

  /* Tarjeta solo a la izquierda del botón; fuera del flujo hasta hover */
  .wa-card {
    position: absolute;
    right: calc(var(--wa-btn-size) + var(--wa-gap));
    bottom: 0;
    width: max-content;
    max-width: min(16rem, calc(100vw - var(--wa-btn-size) - 2.5rem));
    background: white;
    border-radius: 1rem;
    padding: 0.65rem 0.9rem;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
    border: 1px solid rgb(209 250 229);
    font-size: 0.8125rem;
    line-height: 1.35;
    text-align: right;
    color: rgb(51 65 85);
    opacity: 0;
    visibility: hidden;
    transform: translateX(10px);
    transition:
      opacity 0.22s ease,
      transform 0.22s ease,
      visibility 0s linear 0.22s;
    pointer-events: none;
  }

  .wa-widget:hover .wa-card,
  .wa-widget:focus-within .wa-card {
    opacity: 1;
    visibility: visible;
    transform: translateX(0);
    transition-delay: 0s;
    pointer-events: auto;
  }

  /* Touch: sin hover fiable — tarjeta siempre visible */
  @media (hover: none) {
    .wa-card {
      opacity: 1;
      visibility: visible;
      transform: translateX(0);
      pointer-events: auto;
      transition: none;
    }
  }

  .wa-btn {
    position: relative;
    flex: 0 0 auto;
    width: var(--wa-btn-size);
    height: var(--wa-btn-size);
    border-radius: 9999px;
    display: grid;
    place-items: center;
    background: #25d366;
    color: white;
    text-decoration: none;
    overflow: visible;
    isolation: isolate;
    /* Brillo que “sube y baja” con la sombra */
    animation: wa-btn-glow 2.2s ease-in-out infinite;
    transition: transform 0.15s ease;
  }

  .wa-btn:hover {
    transform: scale(1.06);
    animation: none;
    box-shadow:
      0 10px 28px rgba(37, 211, 102, 0.45),
      0 -6px 20px rgba(37, 211, 102, 0.25);
  }

  .wa-btn:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px white, 0 0 0 5px #25d366;
  }

  /* Dos capas de pulso: una sube, otra baja (glow vertical) */
  .wa-pulse {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 100%;
    height: 100%;
    margin-left: calc(var(--wa-btn-size) / -2);
    margin-top: calc(var(--wa-btn-size) / -2);
    border-radius: inherit;
    background: rgba(37, 211, 102, 0.35);
    pointer-events: none;
    z-index: -1;
  }

  .wa-pulse--back {
    animation: wa-pulse-up 1.8s ease-in-out infinite;
  }

  .wa-pulse--front {
    animation: wa-pulse-down 1.8s ease-in-out infinite;
    animation-delay: 0.9s;
    background: rgba(37, 211, 102, 0.22);
  }

  .wa-icon {
    width: 1.5rem;
    height: 1.5rem;
    display: block;
    flex-shrink: 0;
    margin: 0;
  }

  @keyframes wa-btn-glow {
    0%,
    100% {
      box-shadow:
        0 6px 18px rgba(0, 0, 0, 0.2),
        0 10px 22px rgba(37, 211, 102, 0.35),
        0 -4px 14px rgba(37, 211, 102, 0.2);
    }
    50% {
      box-shadow:
        0 10px 26px rgba(0, 0, 0, 0.18),
        0 4px 28px rgba(37, 211, 102, 0.5),
        0 -12px 26px rgba(37, 211, 102, 0.38);
    }
  }

  @keyframes wa-pulse-up {
    0%,
    100% {
      transform: scale(1) translateY(0);
      opacity: 0.55;
    }
    50% {
      transform: scale(1.12, 1.18) translateY(-6px);
      opacity: 0.15;
    }
  }

  @keyframes wa-pulse-down {
    0%,
    100% {
      transform: scale(1.05) translateY(0);
      opacity: 0.4;
    }
    50% {
      transform: scale(1.2, 1.1) translateY(8px);
      opacity: 0.08;
    }
  }

  @media (max-width: 360px) {
    .wa-card {
      right: auto;
      left: 0;
      bottom: calc(var(--wa-btn-size) + var(--wa-gap));
      max-width: calc(100vw - 2rem);
      text-align: center;
    }
    .wa-inner {
      flex-direction: column-reverse;
      align-items: flex-end;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-btn {
      animation: none;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.18);
    }
    .wa-pulse--back,
    .wa-pulse--front {
      animation: none;
      opacity: 0.2;
      transform: scale(1.08);
    }
    .wa-card {
      transition: none;
    }
    .wa-widget:hover .wa-card,
    .wa-widget:focus-within .wa-card {
      transform: none;
    }
    .wa-btn:hover {
      transform: none;
    }
  }
</style>
