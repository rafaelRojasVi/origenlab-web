---
import { site } from '../config/site';
---

<footer class="mt-16 border-t border-slate-200">
  <div class="mx-auto max-w-6xl px-6 py-8">
    <div class="flex flex-wrap items-center justify-between gap-6 text-sm text-slate-600">
      <div>
        <p class="font-medium text-slate-800">{site.name}</p>
        <p>{site.location}</p>
        <p>
          <a href={`mailto:${site.email}`} class="link-muted">{site.email}</a>
        </p>
      </div>
      <p>
        <a href="/contacto" class="link-muted font-medium">Contacto</a>
      </p>
    </div>
  </div>
</footer>
