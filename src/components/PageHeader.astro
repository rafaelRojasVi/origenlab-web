---
interface Props {
  title: string;
  lead?: string;
}

const { title, lead } = Astro.props;
---

<header class="border-b border-slate-200 pb-8">
  <h1 class="text-3xl font-bold text-slate-900 md:text-4xl">{title}</h1>
  {lead && <p class="mt-3 max-w-2xl text-lg text-slate-600">{lead}</p>}
</header>
