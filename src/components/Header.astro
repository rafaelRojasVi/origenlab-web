---
import { site } from '../config/site';
---

<header class="border-b border-slate-200">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-6 py-4">
    <a href="/" class="text-xl font-semibold text-slate-900 hover:text-slate-700">
      {site.name}
    </a>
    <nav class="flex flex-wrap gap-5 text-sm" aria-label="Navegación principal">
      {site.nav.map((item) => (
        <a href={item.href} class="text-slate-600 hover:text-slate-900">
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
