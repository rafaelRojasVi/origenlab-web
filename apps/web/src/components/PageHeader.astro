---
interface Props {
  title: string;
  lead?: string;
}

const { title, lead } = Astro.props;
---

<header class="border-b border-brand-100 pb-8">
  <h1 class="text-3xl font-bold tracking-tight text-brand-950 md:text-4xl">{title}</h1>
  {lead && <p class="mt-3 max-w-2xl text-lg leading-relaxed text-slate-600">{lead}</p>}
</header>
